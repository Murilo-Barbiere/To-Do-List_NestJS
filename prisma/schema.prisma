generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model users {
  id Int @id @default(autoincrement())
  name  String
  email String @unique
  tarefas tarefas[]
}

model tarefas {
  id Int @id @default(autoincrement())
  name String
  descricao String?
  user_id Int 
  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}